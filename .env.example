# ==============================================================================
# VisionAlert — exemplo de configuração
# Copie para .env e preencha. NUNCA commite o .env real.
# ==============================================================================

# --- Django -------------------------------------------------------------------
# Gere com: python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=REPLACE_WITH_RANDOM_64CHAR_STRING
DJANGO_DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# --- Database / Redis ---------------------------------------------------------
DATABASE_URL=postgres://visionuser:CHANGE_ME@db:5432/visionalert
REDIS_URL=redis://redis:6379/0

# --- CORS (frontend origins, separadas por vírgula) ---------------------------
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200

# --- Chaves dedicadas (NÃO reutilize a SECRET_KEY) ----------------------------
# Senhas de câmeras são cifradas com esta chave. Rotacionar requer re-cifrar.
# Gere com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CAMERA_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# Assinatura HMAC dos tokens de stream MJPEG (curtos, 60s de vida)
STREAM_TOKEN_SECRET=REPLACE_WITH_RANDOM_STRING

# Token usado por setup.sh do edge para solicitar provisionamento.
# Se vazio, o endpoint público de registro fica desabilitado (recomendado).
FLEET_PROVISION_TOKEN=

# --- Asaas --------------------------------------------------------------------
ASAAS_API_KEY=
ASAAS_ENVIRONMENT=sandbox
# IPs do Asaas permitidos a chamar o webhook (separados por vírgula). Vazio = permitir todos.
ASAAS_WEBHOOK_IP_ALLOWLIST=

# --- E-mail -------------------------------------------------------------------
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@visionalert.com.br

# --- URL pública do app (usada em e-mails transacionais) ----------------------
APP_BASE_URL=http://localhost:4200

# --- YOLO ---------------------------------------------------------------------
YOLO_MODEL=yolov8n.pt
ANALYSIS_FPS=2
DETECTION_CONFIDENCE=0.5

# --- Anthropic (opcional, só para regra ai_vision) ----------------------------
ANTHROPIC_API_KEY=
