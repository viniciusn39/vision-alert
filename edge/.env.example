# VisionAlert Edge — Environment Variables
# Generated by: python3 agent/register.py

# Central server URL
CENTRAL_URL=https://app.visionalert.com.br

# Device API key (generated during registration — DO NOT SHARE)
DEVICE_KEY=

# Device ID (generated during registration)
DEVICE_ID=

# Redis (internal, don't change)
REDIS_URL=redis://redis:6379

# Agent intervals (seconds)
HEARTBEAT_INTERVAL=60
SYNC_INTERVAL=30
